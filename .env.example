# -----------------------------------------------------------------------------
# Copy this file to ".env" and replace placeholders with real values.
# Never commit ".env" — it is gitignored.
# CI (Xcode Cloud) may copy this file to ".env" when ".env" is absent so builds
# can bundle assets; use Xcode Cloud secrets for production values if needed.
# -----------------------------------------------------------------------------

# App / debugging
DEBUG=false
# Backend API base URL (no trailing slash), e.g. https://api.myfoodrx.example.com
API_BASE_URL=https://api.myfoodrx.example.com

# MongoDB
# Production/staging: use Atlas — Cluster → Connect → Drivers. Use SRV string in local .env only (never commit it).
# Example below = local MongoDB with no auth (no user:password in the URL — safe for git / secret scanners).
MONGODB_URL=mongodb://127.0.0.1:27017/myfoodrx

# Spoonacular / RapidAPI (recipe & ingredient search)
RAPID_API_KEY=your-rapidapi-key-here

# Gmail SMTP (password reset & transactional email)
GMAIL_USER=your-app-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password-here
APP_URL=foodrx://reset-password
EMAIL_FROM_NAME=MyFoodRx

# Google Dialogflow (chatbot) — optional if chatbot is disabled
DIALOGFLOW_PROJECT_ID=your-gcp-project-id-here
DIALOGFLOW_LOCATION=global
DIALOGFLOW_AGENT_ID=your-agent-id-here
DIALOGFLOW_LANGUAGE_CODE=en

# Feature flags (true/false)
SHOW_SCALING_CONVERSION=false
SHOW_TOUR_DEBUG_BUTTON=false
MANDATORY_PLAN_VIDEO=false

# Plan video URLs — Firebase Storage download URL or HTTPS MP4
# Use _FULL for longer/signup variants; base URLs for shorter clips.
DASH_VIDEO_URL=https://firebasestorage.googleapis.com/v0/b/your-bucket/o/dash-plan-video.mp4?alt=media&token=example-token
DASH_VIDEO_URL_FULL=https://firebasestorage.googleapis.com/v0/b/your-bucket/o/dash-plan-video-full.mp4?alt=media&token=example-token
MYPLATE_VIDEO_URL=https://firebasestorage.googleapis.com/v0/b/your-bucket/o/myplate-plan-video.mp4?alt=media&token=example-token
MYPLATE_VIDEO_URL_FULL=https://firebasestorage.googleapis.com/v0/b/your-bucket/o/myplate-plan-video-full.mp4?alt=media&token=example-token
DIABETES_PLATE_VIDEO_URL=https://firebasestorage.googleapis.com/v0/b/your-bucket/o/diabetes-plate-video.mp4?alt=media&token=example-token
DIABETES_PLATE_VIDEO_URL_FULL=https://firebasestorage.googleapis.com/v0/b/your-bucket/o/diabetes-plate-video-full.mp4?alt=media&token=example-token
